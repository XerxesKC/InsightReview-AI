APP_NAME="ReviewPulse Agent"
APP_VERSION=0.1.0
APP_PORT=8001
DEBUG=true
API_V1_PREFIX=/api/v1
# 填入真实 DashScope / OpenAI 兼容密钥；留空时聊天接口会回退到本地占位回复
API_KEY=dev-api-key
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_REWRITE_MODEL_NAME=qwen-turbo
LLM_GENERATION_MODEL_NAME=qwen3.5-flash
# 兼容旧配置（等价于 LLM_GENERATION_MODEL_NAME）
LLM_MODEL_NAME=qwen3.5-flash
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024

# 按本机 MySQL 连接信息修改
DATABASE_URL=mysql+asyncmy://root:your_password@127.0.0.1:3306/review_pulse?charset=utf8mb4
DATABASE_AUTO_CREATE=false
REDIS_URL=redis://localhost:6379/0

CHROMA_PATH=./data/chroma
BGE_MODEL_PATH=./data/bge-model/BAAI/bge-large-zh-v1.5
EMBEDDING_MODELS_ROOT=./data/bge-model
UPLOAD_DIR=./data/files
LOG_DIR=./data/logs
EMBEDDING_DEVICE=auto
MAX_UPLOAD_SIZE_MB=20
ALLOWED_UPLOAD_EXTENSIONS=pdf,docx,txt,md,csv

# 使用 JSON 数组格式，例如：["http://localhost:3000"]
ALLOWED_ORIGINS=["*"]

