APP_NAME="ReviewPulse Agent"
APP_VERSION=0.1.0
APP_PORT=8001
DEBUG=false
API_V1_PREFIX=/api/v1

# Fill these before the final contest demo.
API_KEY=replace_with_real_api_key
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_REWRITE_MODEL_NAME=qwen-turbo
LLM_GENERATION_MODEL_NAME=qwen3.5-flash
LLM_MODEL_NAME=qwen3.5-flash
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024

# Demo database settings.
DATABASE_URL=mysql+asyncmy://root:xjtuse@127.0.0.1:3306/review_pulse_demo?charset=utf8mb4
DATABASE_AUTO_CREATE=false
REDIS_URL=redis://localhost:6379/0

# Demo machine local paths.
CHROMA_PATH=E:/project-xjtuse/reviewpulse-demo-release/data/chroma
BGE_MODEL_PATH=E:/project-xjtuse/ReviewPulse Agent/data/bge-model/BAAI/bge-base-zh-v1.5
EMBEDDING_MODELS_ROOT=E:/project-xjtuse/ReviewPulse Agent/data/bge-model
UPLOAD_DIR=E:/project-xjtuse/reviewpulse-demo-release/demo-data/files
LOG_DIR=E:/project-xjtuse/reviewpulse-demo-release/demo-data/logs
EMBEDDING_DEVICE=auto
MAX_UPLOAD_SIZE_MB=20
ALLOWED_UPLOAD_EXTENSIONS=pdf,docx,txt,md,csv

ALLOWED_ORIGINS=["*"]

# Optional. Leave blank if the core demo path does not require E2B.
E2B_API_KEY=
